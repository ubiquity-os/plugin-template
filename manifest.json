{
  "name": "plugin-template",
  "short_name": "ubiquity-os/plugin-template@main",
  "description": "UbiquityOS plugin template repository with TypeScript support.",
  "ubiquity:listeners": [
    "issue_comment.created",
    "pull_request_review_comment.created"
  ],
  "skipBotEvents": true,
  "configuration": {
    "default": {},
    "type": "object",
    "properties": {
      "configurableResponse": {
        "default": "Hello, world!",
        "type": "string"
      },
      "customStringsUrl": {
        "type": "string"
      }
    }
  },
  "homepage_url": "https://plugin-template.ubiquity-os.deno.net"
}
