{
  "name": "plugin-template",
  "short_name": "gentlementlegen/plugin-template@codex/fix/manifest-build",
  "description": "UbiquityOS plugin template repository with TypeScript support.",
  "commands": {
    "hello": {
      "ubiquity:example": "/hello argument",
      "description": "Hello command with an argument."
    }
  },
  "ubiquity:listeners": [],
  "skipBotEvents": true,
  "configuration": {
    "default": {},
    "type": "object",
    "properties": {
      "configurableResponse": {
        "default": "Hello, world!",
        "type": "string"
      },
      "customStringsUrl": {
        "type": "string"
      }
    }
  }
}
